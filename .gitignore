# Ignore bundler
/.bundle
Gemfile.lock

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE
.idea
.vscode/*
!.vscode/settings.json

# Local agent skills (not versioned; use ~/.cursor/skills or ~/.claude/skills)
.agents/
.claude/skills/
.kiro/skills/

# Ignore coverage
coverage/
.rspec_status

# Ignore temp files
tmp/
*.log
*.gem

# Ignore example app local/runtime artifacts
examples/.env
examples/*/.env
examples/*/.github/
examples/*/.kamal/
examples/*/config/credentials.yml.enc
examples/*/config/master.key

# Ignore local browser verification artifacts
.playwright-mcp/

# Better Auth upstream clone (local parity only)
reference/upstream-src/*/
!reference/upstream-src/README.md
