# frozen_string_literal: true

require "rake/testtask"
require "standard/rake"

desc "Run unit tests without external services"
Rake::TestTask.new(:test) do |task|
  task.libs << "test"
  task.pattern = "test/**/*_test.rb"
end

namespace :test do
  Rake::TestTask.new(:adapter_integration) do |task|
    task.libs << "test"
    task.pattern = "test/better_auth/api_key/adapter_matrix_test.rb"
  end

  Rake::TestTask.new(:redis_integration) do |task|
    task.libs << "test"
    task.pattern = "test/better_auth/api_key/redis_secondary_storage_integration_test.rb"
  end

  desc "Run service-backed integration tests (PostgreSQL/MySQL/MSSQL/Redis)"
  task :integration do
    ENV["BETTER_AUTH_ADAPTER_INTEGRATION"] = "1"
    ENV["REDIS_INTEGRATION"] = "1"
    Rake::Task["test:adapter_integration"].invoke
    Rake::Task["test:redis_integration"].reenable
    Rake::Task["test:redis_integration"].invoke
  end
end

task default: [:test, :standard]
