# frozen_string_literal: true

require "rake/testtask"
require "standard/rake"

ALL_TEST_FILES = FileList["test/**/*_test.rb"].to_a.freeze
ADAPTER_INTEGRATION_TEST_FILES = %w[
  test/better_auth/api_key/adapter_matrix_test.rb
].freeze
REDIS_INTEGRATION_TEST_FILES = %w[
  test/better_auth/api_key/redis_secondary_storage_integration_test.rb
].freeze
INTEGRATION_TEST_FILES = (ADAPTER_INTEGRATION_TEST_FILES + REDIS_INTEGRATION_TEST_FILES).freeze
UNIT_TEST_FILES = (ALL_TEST_FILES - INTEGRATION_TEST_FILES).freeze

unless (UNIT_TEST_FILES & INTEGRATION_TEST_FILES).empty? &&
    (UNIT_TEST_FILES + INTEGRATION_TEST_FILES).sort == ALL_TEST_FILES.sort
  raise "better_auth-api-key test partition must be exhaustive and disjoint"
end

desc "Run unit tests without external services"
Rake::TestTask.new(:test) do |task|
  task.libs << "test"
  task.test_files = FileList[*UNIT_TEST_FILES]
end

namespace :test do
  Rake::TestTask.new(:adapter_integration) do |task|
    task.libs << "test"
    task.test_files = FileList[*ADAPTER_INTEGRATION_TEST_FILES]
  end

  Rake::TestTask.new(:redis_integration) do |task|
    task.libs << "test"
    task.test_files = FileList[*REDIS_INTEGRATION_TEST_FILES]
  end

  desc "Run SQL and MongoDB adapter integration tests"
  task :integration do
    ENV["BETTER_AUTH_ADAPTER_INTEGRATION"] = "1"
    Rake::Task["test:adapter_integration"].invoke
  end
end

task default: [:test, :standard]
