# frozen_string_literal: true

require "bundler/gem_helper"
require "rspec/core/rake_task"

Bundler::GemHelper.install_tasks(name: "better_auth-rails")

desc "Run fast specs without database services"
RSpec::Core::RakeTask.new(:spec) do |task|
  task.rspec_opts = "--tag ~integration"
end

namespace :test do
  desc "Run database integration specs (PostgreSQL/MySQL services required)"
  task :integration do
    sh "bundle exec rspec --tag integration"
  end
end

desc "Run StandardRB linter"
task :lint do
  sh "bundle exec standardrb"
end

desc "Auto-fix StandardRB issues"
task "lint:fix" do
  sh "bundle exec standardrb --fix"
end

desc "Run fast tests without database services"
task test: :spec

desc "Run full CI check (lint + fast tests)"
task ci: [:lint, :test]

task default: :ci
