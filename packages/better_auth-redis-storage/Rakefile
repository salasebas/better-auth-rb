# frozen_string_literal: true

require "rake/testtask"
require "standard/rake"

ALL_TEST_FILES = FileList["test/**/*_test.rb"].to_a.freeze
INTEGRATION_TEST_FILES = %w[
  test/better_auth/redis_storage_integration_test.rb
].freeze
UNIT_TEST_FILES = (ALL_TEST_FILES - INTEGRATION_TEST_FILES).freeze

unless (UNIT_TEST_FILES & INTEGRATION_TEST_FILES).empty? &&
    (UNIT_TEST_FILES + INTEGRATION_TEST_FILES).sort == ALL_TEST_FILES.sort
  raise "better_auth-redis-storage test partition must be exhaustive and disjoint"
end

desc "Run unit tests without external services"
Rake::TestTask.new(:test) do |task|
  task.libs << "test"
  task.test_files = FileList[*UNIT_TEST_FILES]
end

namespace :test do
  Rake::TestTask.new(:redis_integration) do |task|
    task.libs << "test"
    task.test_files = FileList[*INTEGRATION_TEST_FILES]
  end

  desc "Run real Redis integration tests (requires REDIS_URL or local Redis)"
  task :integration do
    ENV["REDIS_INTEGRATION"] = "1"
    Rake::Task["test:redis_integration"].invoke
  end
end

task default: [:test, :standard]
