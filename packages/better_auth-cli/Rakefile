# frozen_string_literal: true

require "bundler/gem_tasks"
require "rake/testtask"

ALL_TEST_FILES = FileList["test/**/*_test.rb"].to_a.freeze
INTEGRATION_TEST_FILES = %w[
  test/better_auth/cli_migrate_parity_test.rb
].freeze
UNIT_TEST_FILES = (ALL_TEST_FILES - INTEGRATION_TEST_FILES).freeze

unless (UNIT_TEST_FILES & INTEGRATION_TEST_FILES).empty? &&
    (UNIT_TEST_FILES + INTEGRATION_TEST_FILES).sort == ALL_TEST_FILES.sort
  raise "better_auth-cli test partition must be exhaustive and disjoint"
end

Rake::TestTask.new(:test) do |t|
  t.libs << "test"
  t.libs << "lib"
  t.libs << "../better_auth/lib"
  t.test_files = FileList[*UNIT_TEST_FILES]
end

namespace :test do
  desc "Run CLI migration parity integration tests"
  Rake::TestTask.new(:integration) do |t|
    t.libs << "test"
    t.libs << "lib"
    t.libs << "../better_auth/lib"
    t.test_files = FileList[*INTEGRATION_TEST_FILES]
  end
end

task default: :test
